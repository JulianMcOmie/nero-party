generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NOTE ON ENUMS: Prisma does not support native `enum` blocks with the SQLite
// connector. `Party.gamePhase` is therefore stored as a String and is strictly
// constrained at the application boundary by the `GamePhase` TypeScript union
// in `src/types/domain.ts` (HOSTING | SUBMITTING | RANKING | REVEAL).

model User {
  id         String   @id @default(uuid())
  name       String
  avatarSeed String
  score      Int      @default(0)
  isHost     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  submittedTracks QueueItem[]       @relation("TrackSubmitter")
  castVotes       RoundSubmission[] @relation("Voter")

  @@index([partyId])
}

model Party {
  id   String @id @default(uuid())
  // Autogenerated 3-digit numeric PIN (e.g. "582"), padded so "042" is valid.
  // Optimized for mobile keypad entry.
  code String @unique

  maxSongs  Int    @default(3)
  // Strongly typed via the `GamePhase` union — see enum note above.
  gamePhase String @default("HOSTING")
  // Active QueueItem id during the RANKING phase. Nullable until rounds begin.
  currentTrackId String?

  // Host configuration toggles
  hideSong                Boolean @default(false)
  hideSubmitterIdentities Boolean @default(false)
  hideLeaderboardUntilEnd Boolean @default(false)

  createdAt DateTime @default(now())

  // Relations
  users       User[]
  queue       QueueItem[]
  submissions RoundSubmission[]
}

model QueueItem {
  id             String  @id @default(uuid())
  spotifyTrackId String
  title          String
  artist         String
  albumArtUrl    String
  previewUrl     String?

  // Running sum of all 1-5 star ratings cast for this track.
  totalRatingScore Int      @default(0)
  revealed         Boolean  @default(false)
  createdAt        DateTime @default(now())

  // Relations
  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  addedByUserId String
  addedBy       User   @relation("TrackSubmitter", fields: [addedByUserId], references: [id], onDelete: Cascade)

  submissions RoundSubmission[]

  @@index([partyId])
  @@index([addedByUserId])
}

model RoundSubmission {
  id String @id @default(uuid())

  // 1-5 star rating. Defaults to 0 ("not yet rated").
  rating Int     @default(0)
  createdAt     DateTime @default(now())

  // Relations
  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  queueItemId String
  queueItem   QueueItem @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  // The voter casting this rating.
  userId String
  voter  User   @relation("Voter", fields: [userId], references: [id], onDelete: Cascade)

  // One submission row per voter per track — enables atomic upserts.
  @@unique([queueItemId, userId])
  @@index([partyId])
  @@index([queueItemId])
}
